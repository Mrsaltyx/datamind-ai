# LLM Provider: "embedded" (Unsloth/llama-cpp local), "ollama" (Ollama server), or "remote" (OpenAI-compatible API)
LLM_PROVIDER=ollama

# Embedded LLM (model file in project) - used when LLM_PROVIDER=embedded
EMBEDDED_MODEL_PATH=models/gemma-4-4b-it-Q4_K_M.gguf
EMBEDDED_GPU_LAYERS=0

# Ollama settings - used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b

# Remote LLM (OpenAI-compatible API) - used when LLM_PROVIDER=remote
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4/
OPENAI_MODEL=glm-5.1

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/sessions.db
